---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import FormatImage from "@components/FormatImage.astro";
import Cta from "@components/cta.astro";
import PageHero from "@components/PageHero.astro";

const allServiceImages = import.meta.glob(
  "/src/content/services/**/*.{jpeg,jpg,png,gif,webp}", { eager: true }
);

// Generate a new path for every collection entry
export async function getStaticPaths() {
  const services = await getCollection("services");
  return services.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry, services },
  }));
}

// Get related services (exclude current, Fisher-Yates shuffle)
function getRelatedServices(services, currentSlug, count = 2) {
  const others = services.filter(s => s.slug !== currentSlug);
  for (let i = others.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [others[i], others[j]] = [others[j], others[i]];
  }
  return others.slice(0, count);
}

// Get the entry directly from the prop on render
const { entry, services } = Astro.props;
const { Content } = await entry.render();
const relatedServices = getRelatedServices(services, entry.slug);

const heroImagePath = Object.keys(allServiceImages).find(p => p.startsWith(`/src/content/services/${entry.slug}/image`));
const heroImage = heroImagePath ? allServiceImages[heroImagePath].default : null;

// Extract FAQ from markdown body
function extractFAQ(body) {
  const faqItems = [];
  const matches = body.matchAll(/\*\*(.+?)\*\*\s*\n(.+?)(?=\n\n|\n\*\*|$)/gs);
  for (const match of matches) {
    const question = match[1].trim();
    const answer = match[2].trim().replace(/\[([^\]]+)\]\([^)]+\)/g, '$1');
    if (question.includes('?')) {
      faqItems.push({ "@type": "Question", "name": question, "acceptedAnswer": { "@type": "Answer", "text": answer } });
    }
  }
  return faqItems;
}

const faqItems = extractFAQ(entry.body);

const serviceSchema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": entry.data.title,
    "description": entry.data.description,
    "provider": { "@id": "https://armadoresmontevideo.uy/#organization" },
    "areaServed": { "@type": "City", "name": "Montevideo" },
    "serviceType": "Armado de Muebles"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://armadoresmontevideo.uy/" },
      { "@type": "ListItem", "position": 2, "name": "Servicios", "item": "https://armadoresmontevideo.uy/servicios" },
      { "@type": "ListItem", "position": 3, "name": entry.data.menu, "item": `https://armadoresmontevideo.uy/servicio/${entry.slug}` }
    ]
  },
  ...(faqItems.length > 0 ? [{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems
  }] : [])
];
---

<Layout title={entry.data.title} description={entry.data.description} schema={serviceSchema}>
  <Container>
    <PageHero
      title={entry.data.title}
      description={entry.data.description}
      image={heroImage}
      breadcrumbs={[
        { label: "Inicio", href: "/" },
        { label: "Servicios", href: "/servicios" },
        { label: entry.data.menu }
      ]}
    />
  </Container>

  <Container>
    <article class="mx-auto prose prose-lg mt-12 max-w-3xl">
      <Content />
    </article>
    <div class="text-center my-8">
      <a href="/servicios" class="bg-gray-100 px-5 py-3 rounded-md hover:bg-gray-200 transition">
        Todos Los Servicios &rarr;
      </a>
    </div>
    <div class="mt-16">
      <h2 class="text-2xl font-bold">Servicios Relacionados</h2>
      <div class="grid sm:grid-cols-2 gap-4 mt-4">
        {relatedServices.map(service => (
          <a href={`/servicio/${service.slug}`} class="block p-4 border rounded-md hover:bg-gray-100 transition">
            <h3 class="text-xl font-semibold">{service.data.menu}</h3>
            <p>{service.data.description}</p>
          </a>
        ))}
      </div>
    </div>
    <Cta/>
  </Container>
</Layout>

<style is:global>
  .prose table {
    @apply w-full text-left text-sm border-collapse overflow-hidden rounded-lg;
    border: 1px solid #e2e8f0;
    box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
  }
  .prose thead {
    @apply bg-slate-800 text-white;
  }
  .prose thead th {
    @apply px-4 py-3 font-semibold border-0;
    color: white;
  }
  .prose thead th:last-child {
    @apply text-right;
  }
  .prose tbody td {
    @apply px-4 py-3 border-0;
  }
  .prose tbody td:last-child {
    @apply text-right whitespace-nowrap font-medium;
  }
  .prose tbody tr {
    @apply border-b border-slate-200 transition-colors;
  }
  .prose tbody tr:nth-child(even) {
    @apply bg-slate-50/50;
  }
  .prose tbody tr:hover {
    @apply bg-slate-100;
  }
</style>
