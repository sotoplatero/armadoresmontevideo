---
import { SEO } from "astro-seo";
import Footer from "@components/footer.astro";
import Navbar from "@components/navbar/navbar.astro";
import "@fontsource-variable/inter/index.css";
import '@fontsource-variable/inter';
import { SITE  } from '../consts';
import Cta from "@components/cta.astro";

export interface Props {
  title: string;
  description?: string;
  schema?: Record<string, any>;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Armadores Montevideo",
  "image": "https://armadoresmontevideo.uy/opengraph.jpg",
  "description": "Servicio profesional de armado de muebles a domicilio en Montevideo. Montaje de roperos, camas, escritorios, estanterías y más.",
  "@id": "https://armadoresmontevideo.uy/#organization",
  "url": "https://armadoresmontevideo.uy",
  "telephone": "+598-95-881-009",
  "email": "soto.platero@gmail.com",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Perez Castellano 1489",
    "addressLocality": "Montevideo",
    "addressRegion": "Montevideo",
    "postalCode": "11000",
    "addressCountry": "UY"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -34.9067,
    "longitude": -56.2122
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
      "opens": "09:00",
      "closes": "19:00"
    }
  ],
  "areaServed": [
    { "@type": "City", "name": "Montevideo" }
  ],
  "serviceType": "Armado de Muebles"
};

const resolvedImageWithDomain = new URL(
  "/opengraph.jpg",
  Astro.site
).toString();

let { title, description, schema } = Astro.props;
title = !!title ? title + " | " + "Armadores Montevideo" : SITE.TITLE
description = description || SITE.DESCRIPTION
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />

    <meta name="generator" content={Astro.generator} />

    <!-- Geo meta tags para SEO local -->
    <meta name="geo.region" content="UY-MO" />
    <meta name="geo.placename" content="Montevideo" />
    <meta name="geo.position" content="-34.9067;-56.2122" />
    <meta name="ICBM" content="-34.9067, -56.2122" />

    <SEO
      title={title}
      description={description}
      canonical={canonicalURL}
      twitter={{
        creator: "@sotoplatero",
        site: "@sotoplatero",
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: title,
          image: resolvedImageWithDomain,
        },
        optional: {
          locale: "es_UY",
        },
      }}
    />
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    {schema && Array.isArray(schema) && schema.map(s => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
    {schema && !Array.isArray(schema) && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
    <script defer src="https://umami.volttus.com/script.js" data-website-id="bf5bf57d-bfa3-4f12-bd45-779fce3715c2"></script>
  </head>
  <body class="overflow-x-hidden">
    <Navbar />
    <slot />
    <Footer />
    <style is:global>
      /* Improve Page speed */
      /* https://css-tricks.com/almanac/properties/c/content-visibility/ */
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>
