---
import BtnWhatsapp from "./ui/BtnWhatsapp.astro";
---

<div id="contacto" class="py-8 sm:py-16">
  <div class="bg-gradient-to-r from-purple-500 to-indigo-600 text-white p-8 md:px-20 md:py-20 mx-auto max-w-screen-xl rounded-lg shadow-lg flex flex-col md:flex-row items-center justify-between text-center md:text-left">
    <div class="w-full max-w-md">
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight">
        Mandanos la foto del mueble
      </h2>
      <p class="text-blue-100 mt-4 text-lg">
        Te respondemos en menos de 1 hora con el precio y coordinamos día y hora. Sin compromiso.
      </p>
    </div>
    <div class="mt-8 md:mt-0">
      <BtnWhatsapp />
    </div>
  </div>
</div>
