---
// @ts-ignore
import { Icon } from "astro-icon/components";

const features = [
  {
    title: "Experiencia real",
    description: "Armamos muebles todos los días. Sabemos cómo funcionan las piezas y cómo resolver los problemas que aparecen.",
    icon: "bx:bxs-wrench",
  },
  {
    title: "Rápido y sin vueltas",
    description: "Llegamos con todo, armamos y nos vamos. La mayoría de los muebles quedan listos en 1-2 horas.",
    icon: "bx:bxs-time-five",
  },
  {
    title: "Mueble firme y seguro",
    description: "Cada tornillo en su lugar, puertas que cierran bien, cajones que corren. Lo revisamos todo antes de irnos.",
    icon: "bx:bxs-shield-alt-2",
  },
  {
    title: "Nos adaptamos a vos",
    description: "Coordinamos el día y horario que te quede mejor. Trabajamos de lunes a sábado.",
    icon: "bx:bxs-calendar-check",
  },
  {
    title: "Garantía incluida",
    description: "Si algo no queda bien, volvemos y lo arreglamos sin costo. Así de simple.",
    icon: "bx:bxs-badge-check",
  },
  {
    title: "Todo tipo de muebles",
    description: "Roperos, camas, escritorios, comedores, estanterías, muebles de cocina. De cualquier marca.",
    icon: "bx:bxs-home",
  },
];
---

<div class="mt-16 md:mt-0 text-center">
  <h2 class="text-3xl lg:text-4xl font-bold lg:tracking-tight">
    Cómo trabajamos
  </h2>
  <p class="text-lg mt-4 text-slate-600">
    Mandás la foto, te damos el precio, coordinamos y listo.
  </p>
</div>

<div class="grid sm:grid-cols-2 md:grid-cols-3 mt-16 gap-16">
  {
    features.map((item) => (
      <div class="flex gap-4 items-start">
        <div class="mt-1 bg-black rounded-full p-2 w-8 h-8 shrink-0">
          <Icon class="text-white" name={item.icon} />
        </div>
        <div>
          <h3 class="font-semibold text-xl">{item.title}</h3>
          <p class="text-slate-500 mt-2 leading-relaxed">{item.description}</p>
        </div>
      </div>
    ))
  }
</div>
