---
import { Picture } from "astro:assets";
import heroImage from "assets/hero2.jpg";
import BtnWhatsapp from "./ui/BtnWhatsapp.astro";
---

<main
  class="grid lg:grid-cols-2 place-items-center py-16 md:pt-12 md:pb-24">
  <div class="py-6 md:order-1">
    <Picture
      src={heroImage}
      alt="Armador de muebles profesional en Montevideo"
      class="aspect-[4/3] object-cover rounded-lg"
      widths={[200, 400, 600]}
      sizes="(max-width: 800px) 100vw, 620px"
      loading="eager"
      format="avif"
    />
  </div>
  <div>
    <h1
      class="text-5xl lg:text-6xl xl:text-7xl font-bold lg:tracking-tight xl:tracking-tighter !leading-[0.85]">
      Armado de Muebles a Domicilio en Montevideo
    </h1>
    <p class="text-lg mt-4 text-slate-600 max-w-xl">
      Armamos roperos, camas, escritorios, comedores y más en tu casa. Llegamos con las herramientas, lo dejamos listo y te damos garantía.
    </p>
    <div class="mt-6 flex flex-col sm:flex-row gap-3 items-start">
      <BtnWhatsapp />
      <a href="/precios" class="text-lg inline-flex items-center text-slate-700 font-medium py-4 px-8 rounded-full border border-slate-300 hover:border-slate-400 transition duration-300">
        Ver precios
      </a>
    </div>
    <p class="mt-4 text-sm text-slate-400">+500 muebles armados en Montevideo</p>
  </div>
</main>
